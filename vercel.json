{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/milkyroots-frontend/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "frontend/dist/milkyroots-frontend/browser/index.html"
    }
  ]
}
