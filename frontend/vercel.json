{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*/",
      "destination": "https://milkyroots-backend-1sk1.vercel.app/api/:path*/"
    },
    {
      "source": "/api/:path*",
      "destination": "https://milkyroots-backend-1sk1.vercel.app/api/:path*/"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
